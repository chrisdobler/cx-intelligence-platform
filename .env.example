# Copy to .env and adjust. Every variable is optional in Phase 1 (defaults shown).

# --- Database ---
DATABASE_URL=postgresql+psycopg://cx:cx@localhost:5432/cx
# Host port the DB container publishes on (override if 5432 is already taken):
# DB_HOST_PORT=5432
# Host port the Adminer database UI publishes on (override if 8080 is taken):
# ADMINER_HOST_PORT=8080
# Open Adminer directly into the dev database. Set to 0 for the login form.
ADMINER_AUTOLOGIN=1

# --- Google AI Studio (Phase 3+) ---
# Free API key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash

# --- Embeddings (Phase 5) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Anomaly alerts (Phase 4) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Pipeline ---
RAW_DATA_PATH=data/raw/sample_tickets_v6.json
# UNDERSTAND_LIMIT=1000
BATCH_SIZE=100

# --- Runtime ---
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
