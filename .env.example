# Copy to .env and adjust. Every variable is optional in Phase 1 (defaults shown).

# --- Database ---
DATABASE_URL=postgresql+psycopg://cx:cx@localhost:5432/cx
# Host port the DB container publishes on (override if 5432 is already taken):
# DB_HOST_PORT=5432
# Host port the Adminer database UI publishes on (override if 8080 is taken):
# ADMINER_HOST_PORT=8080
# Open Adminer directly into the dev database. Set to 0 for the login form.
ADMINER_AUTOLOGIN=1

# --- Google AI Studio (Phase 3+) ---
# Free API key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash

# --- Embeddings (Phase 5) ---
# gemini-embedding-001 reuses GOOGLE_API_KEY above (no separate credential).
# EMBEDDING_DIM must match the knowledge_documents.embedding column (fixed at
# 3072 by migration); changing it requires a new migration.
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072

# --- Anomaly alerts (Phase 4) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Pipeline ---
RAW_DATA_PATH=data/raw/sample_tickets_v6.json
DERIVED_DATA_PATH=data/processed/data-artifacts.tgz
# UNDERSTAND_LIMIT=1000
UNDERSTAND_CONCURRENCY=32
BATCH_SIZE=100

# --- Runtime ---
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
